{
  "compilerOptions": {
    "target": "ES2021",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowJs": true,
    "checkJs": false,
    "jsx": "react-jsx",
    "strict": false,
    "noEmit": true,
    "skipLibCheck": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true
  },
  "include": [
    "src/**/*",
    "docs/**/*.ts",
    "docs/**/*.tsx",
    "docs/**/*.mts",
    "docs/**/*.cts",
    "docs/.vitepress/**/*.ts"
  ]
}
